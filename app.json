{
  "expo": {
    "name": "MoviDgo",
    "slug": "movidgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logoMOVI.png",
    "scheme": "movidgo",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.movidgo.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.movidgo.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoMOVI.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/logoMOVI.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoMOVI.png",
          "imageWidth": 250,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "image": "./assets/images/logoMOVI.png",
            "backgroundColor": "#ffffff"
          }
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MoviDGO necesita tu ubicación para mostrar el mapa."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "MoviDGO necesita acceso a tu galería para foto de perfil.",
          "cameraPermission": "MoviDGO necesita acceso a tu cámara para foto de perfil."
        }
      ],
      [
        "@rnmapbox/maps",
        {}
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5f298aeb-e981-44e7-b484-a50bc02c6495"
      }
    },
    "cli": {
      "appVersionSource": "remote"
    }
  }
}
